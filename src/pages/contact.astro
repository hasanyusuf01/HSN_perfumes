---
import Layout from '../layouts/Layout.astro';
import brand from '../content/settings/brand.json';
---

<Layout title="Contact" description="Get in touch with HSN Perfumes — order via WhatsApp or send us a message.">

  <div class="relative py-20 bg-charcoal/30 border-b border-gold/10">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="font-accent text-xs tracking-[0.4em] uppercase text-gold mb-3 reveal">We're Here</p>
      <h1 class="font-display text-5xl md:text-6xl font-light text-cream reveal reveal-delay-1">
        Get in <span class="italic text-gold">Touch</span>
      </h1>
    </div>
  </div>

  <section class="max-w-6xl mx-auto px-6 lg:px-12 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Contact info -->
      <div class="reveal">
        <h2 class="font-display text-3xl font-light text-cream mb-8">
          Let's <span class="italic text-gold">Talk Fragrance</span>
        </h2>
        <p class="font-body text-cream/60 leading-relaxed mb-10">
          Whether you're looking for a recommendation, placing an order, or simply want to know more about a specific fragrance — we're always happy to chat. The best and fastest way to reach us is via WhatsApp.
        </p>

        <div class="space-y-6">
          <!-- WhatsApp -->
          <div class="glass-card border border-gold/10 hover:border-gold/25 p-6 transition-all duration-300 group">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-gold/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <p class="font-accent text-xs tracking-widest uppercase text-gold mb-1">WhatsApp</p>
                <p class="font-body text-cream/70 text-sm mb-2">Fastest response — order, ask, enquire</p>
                <a href={`https://wa.me/${brand.whatsapp_number}`} target="_blank" rel="noopener" class="font-body text-sm text-gold hover:underline">
                  +{brand.whatsapp_number}
                </a>
              </div>
            </div>
          </div>

          <!-- Instagram -->
          {brand.instagram_url && (
            <div class="glass-card border border-gold/10 hover:border-gold/25 p-6 transition-all duration-300 group">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-gold/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                  <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </div>
                <div>
                  <p class="font-accent text-xs tracking-widest uppercase text-gold mb-1">Instagram</p>
                  <p class="font-body text-cream/70 text-sm mb-2">New arrivals, behind-the-scenes & more</p>
                  <a href={brand.instagram_url} target="_blank" rel="noopener" class="font-body text-sm text-gold hover:underline">
                    @hsnperfumes
                  </a>
                </div>
              </div>
            </div>
          )}

          <!-- Hours -->
          <div class="glass-card border border-gold/10 p-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-gold/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="font-accent text-xs tracking-widest uppercase text-gold mb-1">Hours</p>
                <p class="font-body text-cream/70 text-sm">Monday – Saturday</p>
                <p class="font-body text-sm text-gold">10:00 AM – 7:00 PM IST</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- WhatsApp quick messages -->
      <div class="reveal reveal-delay-2">
        <h2 class="font-display text-3xl font-light text-cream mb-4">
          Quick <span class="italic text-gold">Messages</span>
        </h2>
        <p class="font-body text-cream/50 text-sm mb-8">
          Click any button below to open WhatsApp with a pre-filled message:
        </p>

        <div class="space-y-3">
          {[
            { label: 'Browse Collection', msg: 'Hello HSN Perfumes, I would like to browse your full collection and get recommendations.' },
            { label: 'Ask for Recommendation', msg: 'Hello HSN Perfumes, I need help choosing a fragrance. Can you recommend something based on my preferences?' },
            { label: 'Check Product Availability', msg: 'Hello HSN Perfumes, I would like to check the availability of a specific fragrance.' },
            { label: 'Track My Order', msg: 'Hello HSN Perfumes, I would like to get an update on my recent order.' },
            { label: 'Gift Packaging Query', msg: 'Hello HSN Perfumes, I am interested in gift packaging options for an order.' },
            { label: 'Bulk / Corporate Order', msg: 'Hello HSN Perfumes, I am interested in placing a bulk or corporate order. Please share details.' },
          ].map(item => (
            <a
              href={`https://wa.me/${brand.whatsapp_number}?text=${encodeURIComponent(item.msg)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between gap-4 glass-card border border-white/5 hover:border-gold/25 p-4 group transition-all duration-300"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-gold flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span class="font-body text-sm text-cream/70 group-hover:text-cream transition-colors">{item.label}</span>
              </div>
              <svg class="w-4 h-4 text-cream/20 group-hover:text-gold group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
