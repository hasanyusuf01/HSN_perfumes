---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import brand from '../../content/settings/brand.json';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await product.render();
const data = product.data;

const allProducts = await getCollection('products');
const related = allProducts
  .filter(p => p.data.category === data.category && p.data.slug !== data.slug)
  .slice(0, 3);

import ProductCard from '../../components/ProductCard.astro';

const defaultSize = data.sizes[0] || '';
const productUrl = `${Astro.site || 'https://hsnperfumes.com'}/products/${data.slug}`;

function buildWALink(size: string): string {
  const msg = `Hello HSN Perfumes, I want to order this product:%0A%0AProduct: ${encodeURIComponent(data.name)}%0APrice: ₹${data.price}%0ASize: ${encodeURIComponent(size)}%0AProduct Code: ${data.sku}%0AProduct URL: ${encodeURIComponent(productUrl)}%0A%0APlease confirm availability.`;
  return `https://wa.me/${brand.whatsapp_number}?text=${msg}`;
}
---

<Layout
  title={data.name}
  description={data.short_description}
  image={data.main_image}
>

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-6 lg:px-12 py-4 flex items-center gap-2 font-body text-xs text-cream/30">
    <a href="/" class="hover:text-gold transition-colors">Home</a>
    <span>/</span>
    <a href="/shop" class="hover:text-gold transition-colors">Collection</a>
    <span>/</span>
    <span class="text-cream/60">{data.name}</span>
  </nav>

  <!-- Product Detail -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20">

      <!-- LEFT: Image panel -->
      <div class="animate-fade-up opacity-0" style="animation-fill-mode:forwards; animation-delay:0.1s;">
        <div class="relative aspect-square bg-charcoal overflow-hidden border border-white/5">
          <!-- Background pattern -->
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 50% 50%, #d4af37 1px, transparent 1px); background-size: 20px 20px;"></div>
          <!-- Glow -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-64 h-64 rounded-full bg-gold/10 blur-3xl"></div>
          </div>
          <!-- Bottle illustration -->
          <div class="absolute inset-0 flex items-center justify-center animate-float">
            <svg viewBox="0 0 120 200" class="w-40 h-56 opacity-40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="48" y="6" width="24" height="20" rx="4" fill="#d4af37"/>
              <rect x="44" y="22" width="32" height="10" rx="3" fill="#d4af37"/>
              <path d="M30 42 Q18 60 18 95 Q18 165 60 170 Q102 165 102 95 Q102 60 90 42 Z" fill="#d4af37" opacity="0.25"/>
              <path d="M30 42 Q18 60 18 95 Q18 165 60 170 Q102 165 102 95 Q102 60 90 42 Z" stroke="#d4af37" stroke-width="1.5" fill="none"/>
              <text x="60" y="112" text-anchor="middle" font-family="serif" font-size="11" fill="#d4af37" opacity="0.7">HSN</text>
              <text x="60" y="126" text-anchor="middle" font-family="serif" font-size="7" fill="#d4af37" opacity="0.5">PERFUMES</text>
            </svg>
          </div>

          <!-- Badges overlay -->
          <div class="absolute top-4 left-4 flex flex-col gap-2">
            {data.best_seller && (
              <span class="bg-gold text-obsidian text-xs font-body font-semibold tracking-wider uppercase px-3 py-1">
                Best Seller
              </span>
            )}
            {!data.in_stock && (
              <span class="bg-charcoal text-cream/50 text-xs font-body tracking-wider uppercase px-3 py-1 border border-white/10">
                Sold Out
              </span>
            )}
          </div>
        </div>

        <!-- Fragrance notes visual -->
        <div class="mt-6 p-6 glass-card border border-gold/10">
          <h3 class="font-accent text-xs tracking-[0.3em] uppercase text-gold mb-5">Fragrance Pyramid</h3>
          <div class="space-y-4">
            {data.fragrance_notes.map(note => {
              const [label, ...rest] = note.split(':');
              const noteText = rest.join(':').trim();
              return (
                <div class="flex gap-4 items-start">
                  <span class="font-accent text-xs tracking-widest text-gold/70 w-16 pt-0.5 flex-shrink-0 uppercase">{label}</span>
                  <div class="flex-1 border-t border-gold/10 pt-2">
                    <p class="font-body text-sm text-cream/70">{noteText}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- RIGHT: Product info -->
      <div class="animate-fade-up opacity-0" style="animation-fill-mode:forwards; animation-delay:0.3s;">
        <!-- Category + SKU -->
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-gold/10 text-gold font-accent text-xs tracking-widest uppercase px-3 py-1 border border-gold/20">
            {data.category}
          </span>
          <span class="font-body text-xs text-cream/30 tracking-wider">#{data.sku}</span>
        </div>

        <!-- Name -->
        <h1 class="font-display text-4xl md:text-5xl font-light text-cream mb-3 leading-tight">
          {data.name}
        </h1>

        <!-- Short desc -->
        <p class="font-display italic text-lg text-cream/60 mb-6 leading-relaxed border-l-2 border-gold/30 pl-4">
          {data.short_description}
        </p>

        <!-- Price -->
        <div class="flex items-baseline gap-3 mb-8">
          <span class="font-display text-4xl text-gold">₹{data.price.toLocaleString('en-IN')}</span>
          <span class="font-body text-sm text-cream/40">per bottle</span>
        </div>

        <!-- Divider -->
        <div class="h-px bg-gradient-to-r from-gold/30 via-gold/10 to-transparent mb-8"></div>

        <!-- Size Selection -->
        {data.sizes.length > 0 && (
          <div class="mb-8">
            <label class="font-accent text-xs tracking-[0.3em] uppercase text-gold/70 block mb-3">
              Select Size — <span id="selectedSizeLabel" class="text-cream/60">{defaultSize}</span>
            </label>
            <div class="flex flex-wrap gap-3" id="sizeSelector">
              {data.sizes.map((size, i) => (
                <button
                  class="size-option font-body text-sm tracking-wide px-5 py-2.5 border transition-all duration-200"
                  class:list={[
                    i === 0
                      ? 'border-gold text-gold bg-gold/10'
                      : 'border-white/15 text-cream/50 hover:border-gold/50 hover:text-cream'
                  ]}
                  data-size={size}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- WhatsApp CTA -->
        <a
          id="mainWABtn"
          href={buildWALink(defaultSize)}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-center gap-3 bg-gold hover:bg-gold-light text-obsidian font-body font-bold text-sm tracking-[0.2em] uppercase px-8 py-5 w-full transition-all duration-300 hover:shadow-2xl hover:shadow-gold/30 mb-4 animate-pulse-gold"
          data-whatsapp={brand.whatsapp_number}
          data-name={data.name}
          data-price={data.price}
          data-sku={data.sku}
          data-slug={data.slug}
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Buy on WhatsApp
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>

        <!-- Enquiry link -->
        <a
          href={`https://wa.me/${brand.whatsapp_number}?text=Hello%20HSN%20Perfumes%2C%20I%20have%20a%20question%20about%20${encodeURIComponent(data.name)}%20(${data.sku}).`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 border border-white/10 hover:border-gold/30 text-cream/50 hover:text-gold font-body text-sm tracking-widest uppercase py-3 w-full transition-all duration-300"
        >
          Ask a Question
        </a>

        <!-- Trust strip -->
        <div class="grid grid-cols-3 gap-3 mt-8 pt-8 border-t border-white/5">
          {[
            { icon: '✓', text: 'Authentic' },
            { icon: '✓', text: 'Fast Shipping' },
            { icon: '✓', text: 'Secure' },
          ].map(t => (
            <div class="flex items-center gap-2">
              <span class="text-gold text-sm">{t.icon}</span>
              <span class="font-body text-xs text-cream/40 tracking-wider">{t.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Full Description -->
    <div class="mt-16 lg:mt-20 grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 reveal">
        <div class="ornament-divider mb-8">
          <h2 class="font-accent text-xs tracking-[0.3em] uppercase text-gold whitespace-nowrap px-4">About This Fragrance</h2>
        </div>
        <div class="prose-hsn font-body text-cream/70 leading-relaxed text-base space-y-4">
          <Content />
        </div>
      </div>

      <div class="reveal reveal-delay-2">
        <div class="glass-card border border-gold/10 p-6">
          <h3 class="font-accent text-xs tracking-[0.3em] uppercase text-gold mb-5">Details</h3>
          <dl class="space-y-4">
            <div>
              <dt class="font-body text-xs text-cream/30 tracking-widest uppercase mb-1">Category</dt>
              <dd class="font-body text-sm text-cream/70">{data.category}</dd>
            </div>
            <div>
              <dt class="font-body text-xs text-cream/30 tracking-widest uppercase mb-1">Product Code</dt>
              <dd class="font-body text-sm text-cream/70 font-mono">{data.sku}</dd>
            </div>
            <div>
              <dt class="font-body text-xs text-cream/30 tracking-widest uppercase mb-1">Available Sizes</dt>
              <dd class="font-body text-sm text-cream/70">{data.sizes.join(', ')}</dd>
            </div>
            <div>
              <dt class="font-body text-xs text-cream/30 tracking-widest uppercase mb-1">Availability</dt>
              <dd class={`font-body text-sm ${data.in_stock ? 'text-green-400' : 'text-red-400'}`}>
                {data.in_stock ? 'In Stock' : 'Out of Stock'}
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="py-16 border-t border-gold/10 bg-charcoal/20">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="text-center mb-10 reveal">
          <h2 class="font-display text-3xl font-light text-cream">
            You May Also <span class="italic text-gold">Like</span>
          </h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
          {related.map((rp, i) => (
            <ProductCard
              name={rp.data.name}
              slug={rp.data.slug}
              sku={rp.data.sku}
              price={rp.data.price}
              category={rp.data.category}
              short_description={rp.data.short_description}
              main_image={rp.data.main_image}
              sizes={rp.data.sizes}
              in_stock={rp.data.in_stock}
              best_seller={rp.data.best_seller}
              delay={i + 1}
            />
          ))}
        </div>
      </div>
    </section>
  )}

</Layout>

<script>
  const sizeOptions = document.querySelectorAll('.size-option');
  const mainWABtn = document.getElementById('mainWABtn') as HTMLAnchorElement | null;
  const selectedSizeLabel = document.getElementById('selectedSizeLabel');

  if (mainWABtn) {
    const whatsapp = mainWABtn.dataset.whatsapp || '';
    const name = mainWABtn.dataset.name || '';
    const price = mainWABtn.dataset.price || '';
    const sku = mainWABtn.dataset.sku || '';
    const slug = mainWABtn.dataset.slug || '';
    const productUrl = `${window.location.origin}/products/${slug}`;

    function updateWALink(size: string) {
      const msg = `Hello HSN Perfumes, I want to order this product:%0A%0AProduct: ${encodeURIComponent(name)}%0APrice: ₹${price}%0ASize: ${encodeURIComponent(size)}%0AProduct Code: ${sku}%0AProduct URL: ${encodeURIComponent(productUrl)}%0A%0APlease confirm availability.`;
      mainWABtn!.href = `https://wa.me/${whatsapp}?text=${msg}`;
      if (selectedSizeLabel) selectedSizeLabel.textContent = size;
    }

    sizeOptions.forEach(btn => {
      btn.addEventListener('click', () => {
        sizeOptions.forEach(b => {
          b.classList.remove('border-gold', 'text-gold', 'bg-gold/10');
          b.classList.add('border-white/15', 'text-cream/50');
        });
        btn.classList.add('border-gold', 'text-gold', 'bg-gold/10');
        btn.classList.remove('border-white/15', 'text-cream/50');
        updateWALink((btn as HTMLElement).dataset.size || '');
      });
    });
  }
</script>

<style is:global>
  .prose-hsn h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 400; color: #f7f1e8; margin-bottom: 0.5rem; margin-top: 1.5rem; }
  .prose-hsn p { margin-bottom: 1rem; }
  .prose-hsn strong { color: #d4af37; font-weight: 500; }
  .prose-hsn ul { list-style: none; padding: 0; }
  .prose-hsn ul li::before { content: '◆ '; color: #d4af37; font-size: 0.5rem; margin-right: 0.5rem; vertical-align: middle; }
</style>
