---
import brand from '../content/settings/brand.json';

interface Props {
  name: string;
  slug: string;
  sku: string;
  price: number;
  category: string;
  short_description: string;
  main_image: string;
  sizes: string[];
  in_stock: boolean;
  best_seller?: boolean;
  featured?: boolean;
  delay?: number;
}

const {
  name,
  slug,
  sku,
  price,
  category,
  short_description,
  main_image,
  sizes,
  in_stock,
  best_seller = false,
  delay = 0,
} = Astro.props;

const defaultSize = sizes[0] || '';

function buildWALink(size: string): string {
  const productUrl = `${Astro.site || 'https://hsnperfumes.com'}/products/${slug}`;
  const msg = `Hello HSN Perfumes, I want to order this product:%0A%0AProduct: ${encodeURIComponent(name)}%0APrice: ₹${price}%0ASize: ${encodeURIComponent(size)}%0AProduct Code: ${sku}%0AProduct URL: ${encodeURIComponent(productUrl)}%0A%0APlease confirm availability.`;
  return `https://wa.me/${brand.whatsapp_number}?text=${msg}`;
}
---

<article
  class={`product-card reveal reveal-delay-${delay} group relative flex flex-col bg-charcoal/60 border border-white/5 hover:border-gold/30 overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:shadow-2xl hover:shadow-gold/10`}
  data-name={name}
  data-category={category}
  data-price={price}
>
  <!-- Image container -->
  <a href={`/products/${slug}`} class="relative aspect-[3/4] overflow-hidden bg-obsidian block">
    <!-- Placeholder gradient (shows if image missing) -->
    <div class="absolute inset-0 bg-gradient-to-br from-charcoal via-obsidian to-charcoal"></div>
    <!-- Decorative pattern -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 50% 50%, #d4af37 1px, transparent 1px); background-size: 24px 24px;"></div>
    <!-- Perfume bottle icon placeholder -->
    <div class="absolute inset-0 flex items-center justify-center opacity-20">
      <svg class="w-24 h-24" viewBox="0 0 100 160" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="40" y="5" width="20" height="18" rx="3" fill="#d4af37"/>
        <rect x="35" y="18" width="30" height="8" rx="2" fill="#d4af37"/>
        <path d="M25 35 Q15 50 15 80 Q15 140 50 145 Q85 140 85 80 Q85 50 75 35 Z" fill="#d4af37" opacity="0.4"/>
        <path d="M25 35 Q15 50 15 80 Q15 140 50 145 Q85 140 85 80 Q85 50 75 35 Z" stroke="#d4af37" stroke-width="1.5" fill="none"/>
        <ellipse cx="50" cy="90" rx="20" ry="25" fill="#d4af37" opacity="0.15"/>
      </svg>
    </div>

    <!-- Badges -->
    <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
      {best_seller && (
        <span class="bg-gold text-obsidian text-[10px] font-body font-semibold tracking-[0.15em] uppercase px-2 py-1">
          Best Seller
        </span>
      )}
      {!in_stock && (
        <span class="bg-charcoal/90 text-cream/50 text-[10px] font-body tracking-[0.15em] uppercase px-2 py-1 border border-white/10">
          Sold Out
        </span>
      )}
    </div>

    <!-- Category tag -->
    <div class="absolute top-3 right-3 z-10">
      <span class="bg-obsidian/80 text-gold text-[10px] font-accent tracking-widest uppercase px-2.5 py-1 border border-gold/20">
        {category}
      </span>
    </div>

    <!-- Hover overlay -->
    <div class="absolute inset-0 bg-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <div class="flex-1">
      <a href={`/products/${slug}`} class="block group/title">
        <h3 class="font-display text-lg font-medium text-cream group-hover/title:text-gold transition-colors duration-300 mb-1">
          {name}
        </h3>
      </a>
      <p class="font-body text-xs text-cream/50 tracking-widest uppercase mb-2">{sku}</p>
      <p class="font-body text-sm text-cream/60 leading-relaxed line-clamp-2 mb-4">
        {short_description}
      </p>
    </div>

    <!-- Sizes -->
    {sizes.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {sizes.map((size, i) => (
          <button
            class="size-btn border border-gold/20 text-cream/50 hover:border-gold hover:text-gold text-xs font-body tracking-wider px-2.5 py-1 transition-all duration-200"
            data-size={size}
            data-active={i === 0 ? "true" : "false"}
          >
            {size}
          </button>
        ))}
      </div>
    )}

    <!-- Price + CTA -->
    <div class="flex items-center justify-between gap-3 mt-auto pt-4 border-t border-white/5">
      <div>
        <span class="font-display text-xl font-semibold text-gold">₹{price.toLocaleString('en-IN')}</span>
        <span class="font-body text-xs text-cream/40 ml-1">/ bottle</span>
      </div>

      <a
        href={buildWALink(defaultSize)}
        target="_blank"
        rel="noopener noreferrer"
        class="whatsapp-btn flex items-center gap-2 bg-gold hover:bg-gold-light text-obsidian text-xs font-body font-semibold tracking-widest uppercase px-4 py-2.5 transition-all duration-300 animate-pulse-gold"
        data-name={name}
        data-price={price}
        data-sku={sku}
        data-slug={slug}
        data-whatsapp={brand.whatsapp_number}
        data-sizes={JSON.stringify(sizes)}
      >
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Buy
      </a>
    </div>
  </div>
</article>

<script>
  // Size button selection & WhatsApp link update
  document.querySelectorAll('.product-card').forEach(card => {
    const sizeButtons = card.querySelectorAll('.size-btn');
    const waBtn = card.querySelector('.whatsapp-btn') as HTMLAnchorElement | null;

    if (!waBtn) return;

    const whatsapp = waBtn.dataset.whatsapp || '';
    const name = waBtn.dataset.name || '';
    const price = waBtn.dataset.price || '';
    const sku = waBtn.dataset.sku || '';
    const slug = waBtn.dataset.slug || '';
    const productUrl = `${window.location.origin}/products/${slug}`;

    function updateWALink(size: string) {
      const msg = `Hello HSN Perfumes, I want to order this product:%0A%0AProduct: ${encodeURIComponent(name)}%0APrice: ₹${price}%0ASize: ${encodeURIComponent(size)}%0AProduct Code: ${sku}%0AProduct URL: ${encodeURIComponent(productUrl)}%0A%0APlease confirm availability.`;
      waBtn!.href = `https://wa.me/${whatsapp}?text=${msg}`;
    }

    sizeButtons.forEach(btn => {
      if ((btn as HTMLElement).dataset.active === 'true') {
        btn.classList.add('!border-gold', '!text-gold');
      }

      btn.addEventListener('click', () => {
        sizeButtons.forEach(b => b.classList.remove('!border-gold', '!text-gold'));
        btn.classList.add('!border-gold', '!text-gold');
        updateWALink((btn as HTMLElement).dataset.size || '');
      });
    });
  });
</script>
