---
import brand from '../content/settings/brand.json';
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-40 transition-all duration-500">
  <!-- Top bar -->
  <div id="topbar" class="bg-gold text-obsidian text-center py-2 px-4 text-xs font-body font-medium tracking-widest uppercase transition-all duration-500 overflow-hidden" style="max-height:40px;">
    ✦ Free delivery on orders above ₹5,000 &nbsp;·&nbsp; Order via WhatsApp for instant confirmation ✦
  </div>

  <!-- Main nav -->
  <nav class="bg-obsidian/95 backdrop-blur-md border-b border-gold/10 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex flex-col items-start group">
        <span class="font-accent text-xl lg:text-2xl tracking-[0.15em] text-gold group-hover:text-gold-light transition-colors duration-300">HSN</span>
        <span class="font-display text-[10px] lg:text-xs tracking-[0.35em] uppercase text-cream/60 -mt-1">Perfumes</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-8 lg:gap-10">
        {[
          { href: '/', label: 'Home' },
          { href: '/shop', label: 'Collection' },
          { href: '/about', label: 'Our Story' },
          { href: '/contact', label: 'Contact' },
        ].map(item => (
          <li>
            <a href={item.href} class="nav-link font-body text-sm tracking-widest uppercase text-cream/70 hover:text-gold transition-colors duration-300 relative group">
              {item.label}
              <span class="absolute -bottom-1 left-0 w-0 h-px bg-gold transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Right actions -->
      <div class="flex items-center gap-4">
        <a
          href={`https://wa.me/${brand.whatsapp_number}?text=Hello%20HSN%20Perfumes%2C%20I%20would%20like%20to%20know%20more%20about%20your%20collection.`}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-2 bg-gold/10 hover:bg-gold text-gold hover:text-obsidian border border-gold/40 px-4 py-2 text-xs font-body tracking-widest uppercase transition-all duration-300"
          aria-label="Order on WhatsApp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="hidden lg:inline">Order Now</span>
        </a>

        <!-- Mobile menu button -->
        <button id="menuBtn" class="md:hidden p-2 text-cream/70 hover:text-gold transition-colors" aria-label="Toggle menu">
          <svg id="menuIcon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="closeIcon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="md:hidden hidden bg-charcoal/98 backdrop-blur-lg border-t border-gold/10">
    <ul class="px-6 py-6 flex flex-col gap-5">
      {[
        { href: '/', label: 'Home' },
        { href: '/shop', label: 'Collection' },
        { href: '/about', label: 'Our Story' },
        { href: '/contact', label: 'Contact' },
      ].map(item => (
        <li>
          <a href={item.href} class="font-body text-sm tracking-widest uppercase text-cream/80 hover:text-gold transition-colors">
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-gold/10">
        <a
          href={`https://wa.me/${brand.whatsapp_number}?text=Hello%20HSN%20Perfumes%2C%20I%20would%20like%20to%20know%20more%20about%20your%20collection.`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-gold font-body text-sm tracking-widest uppercase"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Order on WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-[calc(40px+4rem)] lg:h-[calc(40px+5rem)]" id="nav-spacer"></div>

<script>
  const navbar = document.getElementById('navbar');
  const topbar = document.getElementById('topbar');
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  const menuIcon = document.getElementById('menuIcon');
  const closeIcon = document.getElementById('closeIcon');
  const spacer = document.getElementById('nav-spacer');

  let scrolled = false;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60 && !scrolled) {
      scrolled = true;
      topbar?.style.setProperty('max-height', '0');
      topbar?.style.setProperty('padding-top', '0');
      topbar?.style.setProperty('padding-bottom', '0');
      if (spacer) spacer.style.height = window.innerWidth >= 1024 ? '5rem' : '4rem';
    } else if (window.scrollY <= 60 && scrolled) {
      scrolled = false;
      topbar?.style.setProperty('max-height', '40px');
      topbar?.style.setProperty('padding-top', '');
      topbar?.style.setProperty('padding-bottom', '');
      if (spacer) spacer.style.height = '';
    }
  });

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
